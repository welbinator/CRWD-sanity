---
import Layout from '../../layouts/Layout.astro';
import { getPost, urlFor } from '../../lib/sanity';
import { PortableText } from '@portabletext/react';

export const prerender = false;

const { slug } = Astro.params;
const post = await getPost(slug!);
if (!post) return Astro.redirect('/blog');
---

<Layout title={`${post.title} — Cedar Rapids Web Design`} description={post.excerpt ?? ''}>
  <article class="content-page single-post">
    <header class="content-page__header">
      <a href="/blog" class="back-link">← Back to Blog</a>
      {post.mainImage && (
        <img src={urlFor(post.mainImage).width(1200).height(630).url()} alt={post.mainImage.alt ?? post.title} class="single-post__hero-img" />
      )}
      <div class="single-post__meta">
        <span class="content-card__date">{post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Draft'}</span>
        {post.author && <span class="content-card__author">By {post.author}</span>}
      </div>
      <h1>{post.title}</h1>
      {post.excerpt && <p class="single-post__excerpt">{post.excerpt}</p>}
    </header>
    <div class="single-post__body prose">
      <PortableText value={post.body} client:load />
    </div>
  </article>
</Layout>

<style is:global>
  @import '/src/styles/content-pages.css';
</style>
