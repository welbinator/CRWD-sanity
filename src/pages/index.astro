    .slide--contact { padding-bottom: 8rem; }
    .form-row { grid-template-columns: 1fr; }
    .slide-dots { display: none; }

    /* Allow slides to grow taller than viewport on mobile and scroll internally */
    .slide {
      height: auto;
      min-height: 100vh;
      overflow-y: auto;
      overflow-x: hidden;
      position: absolute;
      -webkit-overflow-scrolling: touch;
    }
