---
import Layout from '../layouts/Layout.astro';
import { getSiteSettings, getSlides } from '../lib/sanity';

export const prerender = false;

const settings = await getSiteSettings();
const phone = settings?.phone ?? '319.360.5541';
const phoneUrl = settings?.phoneUrl ?? 'tel:3193605541';
const slides = await getSlides();
---

<Layout>
  <!-- ── HEADER ── -->
  <header class="header">
    <div class="header-container">
      <a href="/" class="header-logo">
        <img src="/assets/images/Cedar-Rapids-Web-Design_Logo_300x40.svg" alt="Cedar Rapids Web Design" width="300" height="40" />
      </a>
      <nav class="nav" id="nav">
        <ul class="nav__list">
          <li><a href="#hero" class="nav__link">Home</a></li>
          <li><a href="#services" class="nav__link">Services</a></li>
          <li><a href="#portfolio" class="nav__link">Portfolio</a></li>
          <li><a href="#team" class="nav__link">Team</a></li>
          <li><a href="#contact-us" class="nav__link">Contact Us</a></li>
        </ul>
      </nav>
      <button class="burger" id="burger" aria-label="Open Navigation" aria-expanded="false">
        <span class="burger__lines"></span>
      </button>
    </div>
  </header>

  <!-- ── SECTIONS ── -->
  <div class="sections" id="sections">

    {slides.map((slide: any) => {
      const anchorId = slide.anchorId ?? slide._id;
      const isDark = slide.textTheme === 'dark';
      const videoUrl = slide.video?.asset?.url;

      if (slide.slideType === 'hero') return (
        <section class={`slide slide--hero`} id={anchorId}>
          {videoUrl ? (
            <video autoplay loop muted playsinline preload="auto" class="slide-video">
              <source src={videoUrl} type="video/mp4" />
            </video>
          ) : (
            <video autoplay loop muted playsinline preload="auto" class="slide-video">
              <source src="/assets/video/Cedar-Rapids-Web-Design_Hero_Video.mp4" type="video/mp4" />
            </video>
          )}
          <div class="slide-video-placeholder"></div>
          <div class="slide__content hero__content">
            <img src="/assets/images/Cedar-Rapids-Web-Design_Logo_500-1.svg" alt="Cedar Rapids Web Design" class="hero__logo" fetchpriority="high" width="500" height="167" />
            {slide.heading && <h1 class="hero__tagline">{slide.heading}</h1>}
            {slide.subheading && <p class="hero__sub">{slide.subheading}</p>}
            {slide.ctas?.length > 0 && (
              <div class="slide__ctas">
                {slide.ctas.map((cta: any) => (
                  <a href={cta.url} class="btn btn--outline">{cta.label}</a>
                ))}
              </div>
            )}
          </div>
        </section>
      );

      if (slide.slideType === 'video-text') {
        const overlayClass = slide.videoOverlay === 'light' ? 'slide-video-placeholder--light' : slide.videoOverlay === 'none' ? '' : 'slide-video-placeholder--dark';
        return (
          <section class={`slide slide--${anchorId}`} id={anchorId}>
            {videoUrl ? (
              <video autoplay loop muted playsinline preload="auto" class="slide-video">
                <source src={videoUrl} type="video/mp4" />
              </video>
            ) : (
              <video autoplay loop muted playsinline preload="auto" class="slide-video">
                <source src={`/assets/video/Cedar-Rapids-Web-Design_${anchorId === 'consultation' ? 'Free-Consultation' : anchorId === 'mobile-friendly' ? 'Mobile-Friendly' : 'SEO-Video-Background'}.mp4`} type="video/mp4" />
              </video>
            )}
            {overlayClass && <div class={`slide-video-placeholder ${overlayClass}`}></div>}
            <div class={`slide__content${isDark ? ' slide__content--dark' : ''}`}>
              <h2 class="slide__heading">{slide.heading}</h2>
              {slide.subheading && <p class="slide__lede">{slide.subheading}</p>}
              {slide.ctas?.length > 0 && (
                <div class="slide__ctas">
                  {slide.ctas.map((cta: any) => (
                    <a href={cta.url} class={`btn ${isDark ? 'btn--outline-dark' : 'btn--outline'}`}>{cta.label}</a>
                  ))}
                </div>
              )}
            </div>
          </section>
        );
      }

      if (slide.slideType === 'services') return (
        <section class="slide slide--services" id={anchorId}>
          <div class="slide__content slide__content--services">
            <div class="services-header">
              <h2 class="slide__heading">{slide.heading ?? 'Services'}</h2>
              {slide.subheading && <p class="slide__lede">{slide.subheading}</p>}
            </div>
        <div class="services-grid">
          <div class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 640 640" xmlns="http://www.w3.org/2000/svg">
                <path fill="currentColor" d="M392.8 65.2C375.8 60.3 358.1 70.2 353.2 87.2L225.2 535.2C220.3 552.2 230.2 569.9 247.2 574.8C264.2 579.7 281.9 569.8 286.8 552.8L414.8 104.8C419.7 87.8 409.8 70.1 392.8 65.2zM457.4 201.3C444.9 213.8 444.9 234.1 457.4 246.6L530.8 320L457.4 393.4C444.9 405.9 444.9 426.2 457.4 438.7C469.9 451.2 490.2 451.2 502.7 438.7L598.7 342.7C611.2 330.2 611.2 309.9 598.7 297.4L502.7 201.4C490.2 188.9 469.9 188.9 457.4 201.4zM182.7 201.3C170.2 188.8 149.9 188.8 137.4 201.3L41.4 297.3C28.9 309.8 28.9 330.1 41.4 342.6L137.4 438.6C149.9 451.1 170.2 451.1 182.7 438.6C195.2 426.1 195.2 405.8 182.7 393.3L109.3 320L182.6 246.6C195.1 234.1 195.1 213.8 182.6 201.3z"/>
              </svg>
            </div>
            <h3 class="service-card__heading">Web Development/Design</h3>
            <p class="service-card__desc">Beautiful, responsive, optimized for search engines (SEO). Cedar Rapids Web Design strives to produce excellent web sites for freelancers, entrepreneurs, small business, eCommerce.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 640 640" xmlns="http://www.w3.org/2000/svg">
                <path fill="currentColor" d="M0 72C0 58.7 10.7 48 24 48L69.3 48C96.4 48 119.6 67.4 124.4 94L162.6 304L472.4 304C483.9 304 493.8 295.8 496 284.5L528.4 115.5C530.9 102.5 543.5 94 556.5 96.5C569.5 99 578 111.6 575.5 124.6L543.1 293.6C536.6 327.5 506.9 352 472.4 352L171.4 352L176.5 380.3C178.6 391.7 188.5 400 200.1 400L456 400C469.3 400 480 410.7 480 424C480 437.3 469.3 448 456 448L200.1 448C165.3 448 135.5 423.1 129.3 388.9L77.2 102.6C76.5 98.8 73.2 96 69.3 96L24 96C10.7 96 0 85.3 0 72zM160 528C160 501.5 181.5 480 208 480C234.5 480 256 501.5 256 528C256 554.5 234.5 576 208 576C181.5 576 160 554.5 160 528zM384 528C384 501.5 405.5 480 432 480C458.5 480 480 501.5 480 528C480 554.5 458.5 576 432 576C405.5 576 384 554.5 384 528zM319 257L247 185C237.6 175.6 237.6 160.4 247 151.1C256.4 141.8 271.6 141.7 280.9 151.1L311.9 182.1L311.9 80C311.9 66.7 322.6 56 335.9 56C349.2 56 359.9 66.7 359.9 80L359.9 182.1L390.9 151.1C400.3 141.7 415.5 141.7 424.8 151.1C434.1 160.5 434.2 175.7 424.8 185L352.8 257C343.4 266.4 328.2 266.4 318.9 257z"/>
              </svg>
            </div>
            <h3 class="service-card__heading">eCommerce</h3>
            <p class="service-card__desc">Do you have a killer product that's selling like hot-cakes and you're wondering what would happen if you started selling…online? Stop wondering and let's do this.</p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 640 640" xmlns="http://www.w3.org/2000/svg">
                <path fill="currentColor" d="M160 144C151.2 144 144 151.2 144 160L144 224C144 232.8 151.2 240 160 240L480 240C488.8 240 496 232.8 496 224L496 160C496 151.2 488.8 144 480 144L160 144zM96 160C96 124.7 124.7 96 160 96L480 96C515.3 96 544 124.7 544 160L544 224C544 259.3 515.3 288 480 288L160 288C124.7 288 96 259.3 96 224L96 160zM360 168C373.3 168 384 178.7 384 192C384 205.3 373.3 216 360 216C346.7 216 336 205.3 336 192C336 178.7 346.7 168 360 168zM416 192C416 178.7 426.7 168 440 168C453.3 168 464 178.7 464 192C464 205.3 453.3 216 440 216C426.7 216 416 205.3 416 192zM160 400C151.2 400 144 407.2 144 416L144 480C144 488.8 151.2 496 160 496L480 496C488.8 496 496 488.8 496 480L496 416C496 407.2 488.8 400 480 400L160 400zM96 416C96 380.7 124.7 352 160 352L480 352C515.3 352 544 380.7 544 416L544 480C544 515.3 515.3 544 480 544L160 544C124.7 544 96 515.3 96 480L96 416zM336 448C336 434.7 346.7 424 360 424C373.3 424 384 434.7 384 448C384 461.3 373.3 472 360 472C346.7 472 336 461.3 336 448zM440 424C453.3 424 464 434.7 464 448C464 461.3 453.3 472 440 472C426.7 472 416 461.3 416 448C416 434.7 426.7 424 440 424z"/>
              </svg>
            </div>
            <h3 class="service-card__heading">Professional Hosting</h3>
            <p class="service-card__desc">A beautiful website can be ruined by slow, unresponsive hosting. Not only is this annoying for viewers, but it also hurts your search engine ranking.</p>
          </div>
        </div>
      </div>
    </section>
      );

      if (slide.slideType === 'portfolio') return (
        <section class="slide slide--portfolio" id={anchorId}>
          <div class="slide__content--dark slide__content--portfolio">
            <div class="portfolio-header">
              <h2 class="slide__heading">{slide.heading ?? 'Portfolio'}</h2>
            </div>
            <div class="portfolio-grid">
              <a href="https://westsidesewing.com" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/westsidesewing.webp" alt="West Side Sewing" class="portfolio-card__img" />
                <div class="portfolio-card__overlay">Visit West Side Sewing</div>
              </a>
              <a href="https://cedarrapidscoworking.space" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/thespace.webp" alt="The Space Coworking" class="portfolio-card__img" />
                <div class="portfolio-card__overlay">Visit The Space Coworking</div>
              </a>
              <a href="https://roadmapwp.com" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/roadmapwp.webp" alt="RoadMapWP" class="portfolio-card__img" />
                <div class="portfolio-card__overlay">Visit RoadMapWP</div>
              </a>
              <a href="https://therepo.org" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/thereposcreenshot.webp" alt="The Repo" class="portfolio-card__img" />
                <div class="portfolio-card__overlay">Visit The Repo</div>
              </a>
              <a href="https://finnprep.com" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/finnprep-hero.webp" alt="FinnPREP" class="portfolio-card__img" />
                <div class="portfolio-card__overlay">Visit FinnPREP</div>
              </a>
              <a href="https://chromebook.guide" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/Cedar-Rapids-Web-Design_Portfolio_Chromebook-Guide1.webp" alt="Chromebook Guide" class="portfolio-card__img" />
                <div class="portfolio-card__overlay">Visit Chromebook Guide</div>
              </a>
            </div>
          </div>
        </section>
      );

      if (slide.slideType === 'team') return (
        <section class="slide slide--team" id={anchorId}>
          <div class="slide__content slide__content--team">
            {slide.heading && <div class="team-header"><h2 class="slide__heading">{slide.heading}</h2></div>}
            <div class="team-grid">
              <div class="team-card">
                <div class="team-card__header">
                  <img src="/assets/images/devingreen_profile-100x100-1.webp" alt="Devin Green" class="team-card__photo" />
                  <div class="team-card__info">
                    <h3 class="team-card__name">Devin Green</h3>
                    <p class="team-card__title">Lead Designer</p>
                    <div class="team-card__socials">
                      <a href="https://twitter.com/artistro08" class="team-social" aria-label="Twitter"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1em" height="1em" fill="currentColor"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8l164.9-188.5L26.8 48h145.6l100.5 132.9L389.2 48zm-24.8 373.8h39.1L151.1 88h-42l255.3 333.8z"/></svg></a>
                      <a href="https://www.facebook.com/artistro08" class="team-social" aria-label="Facebook"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" width="1em" height="1em" fill="currentColor"><path d="M80 299.3V512H196V299.3h86.5l18-97.8H196V166.9c0-51.7 20.3-71.5 72.7-71.5c16.3 0 29.4 .4 37 1.2V7.9C291.4 4 256.4 0 236.2 0C129.3 0 80 50.5 80 159.4v42.1H14v97.8H80z"/></svg></a>
                    </div>
                  </div>
                </div>
                <div class="team-card__bio">
                  <p>Devin loves graphic and web design. With over 11 years experience in graphic design and 7 years in web design, his preferred tools are Adobe Photoshop, Illustrator, and Webflow.</p>
                  <p>When he's not designing, Devin works on his clothing line <a href="https://styleclothing.co/" target="_blank" rel="noopener">Style Clothing Co.</a></p>
                  <p>Check out Devin's work at <a href="https://devingreen.me/" target="_blank" rel="noopener">devingreen.me</a></p>
                </div>
              </div>
              <div class="team-card">
                <div class="team-card__header">
                  <img src="/assets/images/Cedar-Rapids-Web-Design_James-Welbes_profile-100x100-1.webp" alt="James Welbes" class="team-card__photo" />
                  <div class="team-card__info">
                    <h3 class="team-card__name">James Welbes</h3>
                    <p class="team-card__title">Owner / Lead Developer</p>
                    <div class="team-card__socials">
                      <a href="https://twitter.com/jameswelbes" class="team-social" aria-label="Twitter"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1em" height="1em" fill="currentColor"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8l164.9-188.5L26.8 48h145.6l100.5 132.9L389.2 48zm-24.8 373.8h39.1L151.1 88h-42l255.3 333.8z"/></svg></a>
                      <a href="https://linkedin.com/in/JamesWelbes" class="team-social" aria-label="LinkedIn"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="1em" height="1em" fill="currentColor"><path d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zm282.1 243h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"/></svg></a>
                    </div>
                  </div>
                </div>
                <div class="team-card__bio">
                  <p>James has been building websites since he was 13. Mostly WordPress, but he dabbles in Webflow, October CMS, and good old fashioned code.</p>
                  <p>Whatever you need done, James can do it. And if he can't, he'll figure it out.</p>
                </div>
              </div>
            </div>
          </div>
        </section>
      );

      if (slide.slideType === 'contact') return (
        <section class="slide slide--contact" id={anchorId}>
          <div class="slide__content slide__content--contact">
            <div class="contact-text">
              <h2 class="slide__heading">{slide.heading ?? 'Contact Us'}</h2>
              {slide.subheading && <p>{slide.subheading}</p>}
              <p>The more details you provide, the more accurate our estimate will be.</p>
              <a href={phoneUrl} class="contact__phone">{phone}</a>
            </div>
            <form class="contact-form" id="contactForm">
              <div class="form-row">
                <div class="form-group">
                  <label for="name">Name <span class="required">*</span></label>
                  <input type="text" id="name" name="name" required placeholder="Your name" />
                </div>
                <div class="form-group">
                  <label for="email">Email <span class="required">*</span></label>
                  <input type="email" id="email" name="email" required placeholder="your@email.com" />
                </div>
              </div>
              <div class="form-group">
                <label for="phone-field">Phone</label>
                <input type="tel" id="phone-field" name="phone" placeholder="319-555-0100" />
              </div>
              <div class="form-group">
                <label for="message">Tell us about your project <span class="required">*</span></label>
                <textarea id="message" name="message" rows="5" required placeholder="Describe your project..."></textarea>
              </div>
              <button type="submit" class="btn btn--solid" id="contactSubmit">Send Message</button>
              <p id="contactSuccess" style="display:none;color:#4caf50;margin-top:0.75rem;font-weight:600;">✓ Message sent! We'll be in touch soon.</p>
              <p id="contactError" style="display:none;color:#e63946;margin-top:0.75rem;font-weight:600;">Something went wrong. Please try again or email us directly.</p>
            </form>
          </div>
          <div class="contact-footer-bar">
            <span>© 2026 Cedar Rapids Web Design · Cedar Rapids, Iowa</span>
            <span><a href={phoneUrl}>{phone}</a> · <a href={`mailto:${settings?.email ?? 'hello@cedarrapidswebdesign.com'}`}>{settings?.email ?? 'hello@cedarrapidswebdesign.com'}</a></span>
          </div>
        </section>
      );

      return null;
    })}

  </div><!-- end .sections -->

</Layout>

<style is:global>
  /* ── RESET / BASE ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { font-family: 'Roboto', sans-serif; background: #000; color: #fff; scroll-behavior: smooth; }

  /* ── HEADER ── */
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 0 2rem;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 1px 0 rgba(0,0,0,0.08);
  }
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }
  .header-logo img { height: 32px; width: auto; display: block; }

  /* Nav */
  .nav__list { list-style: none; display: flex; gap: 2rem; }
  .nav__link {
    color: #222;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav__link:hover { color: #e63946; }

  /* Burger */
  .burger { display: none; flex-direction: column; justify-content: center; gap: 5px; width: 36px; height: 36px; cursor: pointer; background: none; border: none; }
  .burger__lines,
  .burger__lines::before,
  .burger__lines::after {
    display: block; width: 24px; height: 2px; background: #222;
    transition: transform 0.3s, opacity 0.3s;
    position: relative;
  }
  .burger__lines::before,
  .burger__lines::after { content: ''; position: absolute; left: 0; }
  .burger__lines::before { top: -7px; }
  .burger__lines::after { top: 7px; }
  .burger[aria-expanded="true"] .burger__lines { background: transparent; }
  .burger[aria-expanded="true"] .burger__lines::before { transform: rotate(45deg) translate(5px, 5px); }
  .burger[aria-expanded="true"] .burger__lines::after { transform: rotate(-45deg) translate(5px, -5px); }

  /* ── SECTIONS WRAPPER ── */
  .sections {
    width: 100%;
  }

  /* ── SLIDES (now normal stacked sections) ── */
  .slide {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 70px;
    isolation: isolate;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .slide.slide--visible {
    opacity: 1;
    transform: translateY(0);
  }
  /* First slide visible immediately (no fade-in wait) */
  .slide:first-child {
    opacity: 1;
    transform: translateY(0);
  }

  /* Video bg */
  .slide-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .slide-video-placeholder {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0,0,0,0.45);
    pointer-events: none;
  }
  .slide-video-placeholder--dark { background: rgba(0,0,0,0.55); }
  .slide-video-placeholder--light { background: rgba(255,255,255,0.35); }

  /* Slide content */
  .slide__content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    width: 100%;
    padding: 2rem;
    text-align: center;
    color: #fff;
  }
  .slide__content--dark { color: #111; }
  .slide__heading {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    text-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }
  .slide__content--dark .slide__heading { text-shadow: none; }
  .slide__lede {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 600;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto 2rem;
    opacity: 0.92;
  }

  /* Hero */
  .slide--hero { background: #0a0a14; }
  .slide--consultation { background: #1a3a5c; }
  .slide--mobile { background: #1a2e1a; }
  .slide--seo { background: #e8e8e8; }
  .hero__logo { max-width: 320px; width: 70%; margin: 0 auto 1.5rem; filter: brightness(0) invert(1); }
  .hero__tagline { font-size: clamp(1.2rem, 3vw, 2rem); font-weight: 300; letter-spacing: 0.2em; text-transform: uppercase; opacity: 0.9; margin-bottom: 0.5rem; }
  .hero__sub { font-size: 1rem; opacity: 0.6; margin-bottom: 2rem; }

  /* CTAs */
  .slide__ctas { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    cursor: pointer;
  }
  .btn--outline {
