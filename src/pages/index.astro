---
import Layout from '../layouts/Layout.astro';
import { getSiteSettings, getSlides } from '../lib/sanity';

export const prerender = false;

const settings = await getSiteSettings();
const phone = settings?.phone ?? '319.360.5541';
const phoneUrl = settings?.phoneUrl ?? 'tel:3193605541';
const slides = await getSlides();
---

<Layout>
  <!-- ── HEADER ── -->
  <header class="header">
    <div class="header-container">
      <a href="/" class="header-logo">
        <img src="/assets/images/Cedar-Rapids-Web-Design_Logo_300x40.svg" alt="Cedar Rapids Web Design" width="300" height="40" />
      </a>
      <nav class="nav" id="nav">
        <ul class="nav__list">
          <li><a href="#hero" class="nav__link">Home</a></li>
          <li><a href="#services" class="nav__link">Services</a></li>
          <li><a href="#portfolio" class="nav__link">Portfolio</a></li>
          <li><a href="#team" class="nav__link">Team</a></li>
          <li><a href="#contact-us" class="nav__link">Contact Us</a></li>
        </ul>
      </nav>
      <button class="burger" id="burger" aria-label="Open Navigation" aria-expanded="false">
        <span class="burger__lines"></span>
      </button>
    </div>
  </header>

  <!-- ── SLIDESHOW WRAPPER ── -->
  <div class="slideshow" id="slideshow">

    {slides.map((slide: any) => {
      const anchorId = slide.anchorId ?? slide._id;
      const isDark = slide.textTheme === 'dark';
      const videoUrl = slide.video?.asset?.url;

      if (slide.slideType === 'hero') return (
        <section class={`slide slide--hero`} id={anchorId}>
          {videoUrl ? (
            <video autoplay loop muted playsinline preload="auto" class="slide-video">
              <source src={videoUrl} type="video/mp4" />
            </video>
          ) : (
            <video autoplay loop muted playsinline preload="auto" class="slide-video">
              <source src="/assets/video/Cedar-Rapids-Web-Design_Hero_Video.mp4" type="video/mp4" />
            </video>
          )}
          <div class="slide-video-placeholder"></div>
          <div class="slide__content hero__content">
          <figure class="hero-logo-figure"><img src="/assets/images/Cedar-Rapids-Web-Design_Logo_500-1.svg" alt="Cedar Rapids Web Design" class="hero__logo" fetchpriority="high" /></figure>
            
          </div>
        </section>
      );

      if (slide.slideType === 'video-text') {
        const overlayClass = slide.videoOverlay === 'light' ? 'slide-video-placeholder--light' : slide.videoOverlay === 'none' ? '' : 'slide-video-placeholder--dark';
        return (
          <section class={`slide slide--${anchorId}`} id={anchorId}>
            {videoUrl ? (
              <video autoplay loop muted playsinline preload="auto" class="slide-video">
                <source src={videoUrl} type="video/mp4" />
              </video>
            ) : (
              <video autoplay loop muted playsinline preload="auto" class="slide-video">
                <source src={`/assets/video/Cedar-Rapids-Web-Design_${anchorId === 'consultation' ? 'Free-Consultation' : anchorId === 'mobile-friendly' ? 'Mobile-Friendly' : 'SEO-Video-Background'}.mp4`} type="video/mp4" />
              </video>
            )}
            {overlayClass && <div class={`slide-video-placeholder ${overlayClass}`}></div>}
            <div class={`slide__content${isDark ? ' slide__content--dark' : ''}`}>
              <h2 class="slide__heading">{slide.heading}</h2>
              {slide.subheading && <p class="slide__lede">{slide.subheading}</p>}
              {slide.ctas?.length > 0 && (
                <div class="slide__ctas">
                  {slide.ctas.map((cta: any) => (
                    <a href={cta.url} class={`btn ${isDark ? 'btn--outline-dark' : 'btn--outline'}`}>{cta.label}</a>
                  ))}
                </div>
              )}
            </div>
          </section>
        );
      }

      if (slide.slideType === 'services') return (
        <section class="slide slide--services" id={anchorId}>
          <div class="slide__content slide__content--services">
            <div class="services-header">
              <h2 class="slide__heading">{slide.heading ?? 'Services'}</h2>
              {slide.subheading && <p class="slide__lede">{slide.subheading}</p>}
            </div>
            <div class="services-grid">

              <article class="service-card" tabindex="0">
                <div class="service-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                </div>
                <h3 class="service-card__heading">Web Development</h3>
                <p class="service-card__desc">We build fast, reliable, and scalable websites from the ground up. From marketing sites to complex web applications, our code is built to perform and last.</p>
              </article>

              <article class="service-card" tabindex="0">
                <div class="service-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"></circle><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"></circle><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"></circle><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"></circle><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"></path></svg>
                </div>
                <h3 class="service-card__heading">UI/UX Design</h3>
                <p class="service-card__desc">User-centered design that balances aesthetics with usability. We create interfaces that are intuitive, accessible, and aligned with your brand identity.</p>
              </article>

              <article class="service-card" tabindex="0">
                <div class="service-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"></circle><circle cx="19" cy="21" r="1"></circle><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path></svg>
                </div>
                <h3 class="service-card__heading">E-Commerce Solutions</h3>
                <p class="service-card__desc">Online stores built for conversion. We handle product catalogs, payment integration, inventory management, and everything in between.</p>
              </article>

              <article class="service-card" tabindex="0">
                <div class="service-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"></rect><rect width="20" height="8" x="2" y="14" rx="2" ry="2"></rect><line x1="6" x2="6.01" y1="6" y2="6"></line><line x1="6" x2="6.01" y1="18" y2="18"></line></svg>
                </div>
                <h3 class="service-card__heading">Hosting &amp; Maintenance</h3>
                <p class="service-card__desc">Reliable hosting infrastructure with proactive monitoring, regular updates, and performance optimization to keep your site running smoothly.</p>
              </article>

              <article class="service-card" tabindex="0">
                <div class="service-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
                </div>
                <h3 class="service-card__heading">SEO &amp; Performance</h3>
                <p class="service-card__desc">Technical SEO audits, page speed optimization, and structured data implementation to ensure your site ranks well and loads fast.</p>
              </article>

              <article class="service-card" tabindex="0">
                <div class="service-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"></rect><path d="M12 18h.01"></path></svg>
                </div>
                <h3 class="service-card__heading">Responsive Design</h3>
                <p class="service-card__desc">Pixel-perfect experiences across every device and screen size. We ensure your site looks and works great on desktop, tablet, and mobile.</p>
              </article>

              <article class="service-card" tabindex="0">
                <div class="service-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"></path><path d="M18 17V9"></path><path d="M13 17V5"></path><path d="M8 17v-3"></path></svg>
                </div>
                <h3 class="service-card__heading">Analytics &amp; Reporting</h3>
                <p class="service-card__desc">Data-driven insights to understand your users. We set up tracking, dashboards, and reporting so you can make informed decisions.</p>
              </article>

              <article class="service-card" tabindex="0">
                <div class="service-icon-box">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg>
                </div>
                <h3 class="service-card__heading">Security &amp; Compliance</h3>
                <p class="service-card__desc">Protection against vulnerabilities with SSL certificates, security audits, GDPR compliance, and regular backup systems.</p>
              </article>

            </div>
          </div>
        </section>
      );

      if (slide.slideType === 'portfolio') return (
        <section class="slide slide--portfolio" id={anchorId}>
          <div class="slide__content--dark slide__content--portfolio">
            <div class="portfolio-header">
              <h2 class="slide__heading">{slide.heading ?? 'Portfolio'}</h2>
            </div>
            <div class="portfolio-grid">
              <a href="https://westsidesewing.com" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/westsidesewing.webp" srcset="/assets/images/portfolio-sm/westsidesewing.webp 450w, /assets/images/westsidesewing.webp 815w" sizes="(max-width: 600px) 450px, 815px" alt="West Side Sewing" class="portfolio-card__img" width="815" height="390" loading="lazy" decoding="async" />
                <div class="portfolio-card__overlay">Visit West Side Sewing</div>
              </a>
              <a href="https://cedarrapidscoworking.space" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/thespace.webp" srcset="/assets/images/portfolio-sm/thespace.webp 450w, /assets/images/thespace.webp 817w" sizes="(max-width: 600px) 450px, 817px" alt="The Space Coworking" class="portfolio-card__img" width="817" height="390" loading="lazy" decoding="async" />
                <div class="portfolio-card__overlay">Visit The Space Coworking</div>
              </a>
              <a href="https://roadmapwp.com" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/roadmapwp.webp" srcset="/assets/images/portfolio-sm/roadmapwp.webp 450w, /assets/images/roadmapwp.webp 815w" sizes="(max-width: 600px) 450px, 815px" alt="RoadMapWP" class="portfolio-card__img" width="815" height="390" loading="lazy" decoding="async" />
                <div class="portfolio-card__overlay">Visit RoadMapWP</div>
              </a>
              <a href="https://therepo.org" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/thereposcreenshot.webp" srcset="/assets/images/portfolio-sm/thereposcreenshot.webp 450w, /assets/images/thereposcreenshot.webp 815w" sizes="(max-width: 600px) 450px, 815px" alt="The Repo" class="portfolio-card__img" width="815" height="390" loading="lazy" decoding="async" />
                <div class="portfolio-card__overlay">Visit The Repo</div>
              </a>
              <a href="https://finnprep.com" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/finnprep-hero.webp" srcset="/assets/images/portfolio-sm/finnprep-hero.webp 450w, /assets/images/finnprep-hero.webp 880w" sizes="(max-width: 600px) 450px, 880px" alt="FinnPREP" class="portfolio-card__img" width="880" height="390" loading="lazy" decoding="async" />
                <div class="portfolio-card__overlay">Visit FinnPREP</div>
              </a>
              <a href="https://chromebook.guide" target="_blank" rel="noopener" class="portfolio-card">
                <img src="/assets/images/Cedar-Rapids-Web-Design_Portfolio_Chromebook-Guide1.webp" srcset="/assets/images/portfolio-sm/Cedar-Rapids-Web-Design_Portfolio_Chromebook-Guide1.webp 450w, /assets/images/Cedar-Rapids-Web-Design_Portfolio_Chromebook-Guide1.webp 822w" sizes="(max-width: 600px) 450px, 822px" alt="Chromebook Guide" class="portfolio-card__img" width="822" height="390" loading="lazy" decoding="async" />
                <div class="portfolio-card__overlay">Visit Chromebook Guide</div>
              </a>
            </div>
          </div>
        </section>
      );

      if (slide.slideType === 'team') return (
        <section class="slide slide--team" id={anchorId}>
          <div class="slide__content slide__content--team">
            {slide.heading && <div class="team-header"><h2 class="slide__heading">{slide.heading}</h2></div>}
            <div class="team-grid">
              <div class="team-card">
                <div class="team-card__header">
                  <img src="/assets/images/devingreen_profile-100x100-1.webp" alt="Devin Green" class="team-card__photo" />
                  <div class="team-card__info">
                    <h3 class="team-card__name">Devin Green</h3>
                    <p class="team-card__title">Lead Designer</p>
                    <div class="team-card__socials">
                      <a href="https://twitter.com/artistro08" class="team-social" aria-label="Twitter"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1em" height="1em" fill="currentColor"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8l164.9-188.5L26.8 48h145.6l100.5 132.9L389.2 48zm-24.8 373.8h39.1L151.1 88h-42l255.3 333.8z"/></svg></a>
                      <a href="https://www.facebook.com/artistro08" class="team-social" aria-label="Facebook"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" width="1em" height="1em" fill="currentColor"><path d="M80 299.3V512H196V299.3h86.5l18-97.8H196V166.9c0-51.7 20.3-71.5 72.7-71.5c16.3 0 29.4 .4 37 1.2V7.9C291.4 4 256.4 0 236.2 0C129.3 0 80 50.5 80 159.4v42.1H14v97.8H80z"/></svg></a>
                    </div>
                  </div>
                </div>
                <div class="team-card__bio">
                  <p>Devin loves graphic and web design. With over 11 years experience in graphic design and 7 years in web design, his preferred tools are Adobe Photoshop, Illustrator, and Webflow.</p>
                  <p>When he's not designing, Devin works on his clothing line <a href="https://styleclothing.co/" target="_blank" rel="noopener">Style Clothing Co.</a></p>
                  <p>Check out Devin's work at <a href="https://devingreen.me/" target="_blank" rel="noopener">devingreen.me</a></p>
                </div>
              </div>
              <div class="team-card">
                <div class="team-card__header">
                  <img src="/assets/images/Cedar-Rapids-Web-Design_James-Welbes_profile-100x100-1.webp" alt="James Welbes" class="team-card__photo" />
                  <div class="team-card__info">
                    <h3 class="team-card__name">James Welbes</h3>
                    <p class="team-card__title">Owner / Lead Developer</p>
                    <div class="team-card__socials">
                      <a href="https://twitter.com/jameswelbes" class="team-social" aria-label="Twitter"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1em" height="1em" fill="currentColor"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8l164.9-188.5L26.8 48h145.6l100.5 132.9L389.2 48zm-24.8 373.8h39.1L151.1 88h-42l255.3 333.8z"/></svg></a>
                      <a href="https://linkedin.com/in/JamesWelbes" class="team-social" aria-label="LinkedIn"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="1em" height="1em" fill="currentColor"><path d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zm282.1 243h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"/></svg></a>
                    </div>
                  </div>
                </div>
                <div class="team-card__bio">
                  <p>James has been building websites since he was 13. Mostly WordPress, but he dabbles in Webflow, October CMS, and good old fashioned code.</p>
                  <p>Whatever you need done, James can do it. And if he can't, he'll figure it out.</p>
                </div>
              </div>
            </div>
          </div>
        </section>
      );

      if (slide.slideType === 'contact') return (
        <section class="slide slide--contact" id={anchorId}>
          <div class="slide__content slide__content--contact">
            <div class="contact-text">
              <h2 class="slide__heading">{slide.heading ?? 'Contact Us'}</h2>
              {slide.subheading && <p>{slide.subheading}</p>}
              <p>The more details you provide, the more accurate our estimate will be.</p>
              <a href={phoneUrl} class="contact__phone">{phone}</a>
            </div>
            <form class="contact-form" id="contactForm">
              <div class="form-row">
                <div class="form-group">
                  <label for="name">Name <span class="required">*</span></label>
                  <input type="text" id="name" name="name" required placeholder="Your name" />
                </div>
                <div class="form-group">
                  <label for="email">Email <span class="required">*</span></label>
                  <input type="email" id="email" name="email" required placeholder="your@email.com" />
                </div>
              </div>
              <div class="form-group">
                <label for="phone-field">Phone</label>
                <input type="tel" id="phone-field" name="phone" placeholder="319-555-0100" />
              </div>
              <div class="form-group">
                <label for="message">Tell us about your project <span class="required">*</span></label>
                <textarea id="message" name="message" rows="5" required placeholder="Describe your project..."></textarea>
              </div>
              <button type="submit" class="btn btn--solid" id="contactSubmit">Send Message</button>
              <p id="contactSuccess" style="display:none;color:#4caf50;margin-top:0.75rem;font-weight:600;">✓ Message sent! We'll be in touch soon.</p>
              <p id="contactError" style="display:none;color:#e63946;margin-top:0.75rem;font-weight:600;">Something went wrong. Please try again or email us directly.</p>
            </form>
          </div>
          <div class="contact-footer-bar">
            <span>© 2026 Cedar Rapids Web Design · Cedar Rapids, Iowa</span>
            <span><a href={phoneUrl}>{phone}</a> · <a href={`mailto:${settings?.email ?? 'hello@cedarrapidswebdesign.com'}`}>{settings?.email ?? 'hello@cedarrapidswebdesign.com'}</a></span>
          </div>
        </section>
      );

      return null;
    })}

  </div><!-- end .slideshow -->

  <!-- ── MOBILE ARROWS ── -->
  <div class="mobile-arrows">
    <button class="mobile-arrow" id="prevBtn" aria-label="Previous slide">&#8592;</button>
    <button class="mobile-arrow" id="nextBtn" aria-label="Next slide">&#8594;</button>
  </div>

  <!-- ── SLIDE DOTS ── -->
  <nav class="slide-dots" id="slideDots" aria-label="Slide navigation">
    {slides.map((slide: any, i: number) => (
      <button class={`dot${i === 0 ? ' dot--active' : ''}`} data-slide={i} aria-label={`Slide ${i + 1}: ${slide.title}`} aria-pressed={i === 0 ? "true" : "false"}></button>
    ))}
  </nav>

<script id="slide-ids-data" type="application/json" set:html={JSON.stringify(slides.map((s: any) => s.anchorId ?? s._id))}></script>
</Layout>

<style is:global>
  /* ── RESET / BASE ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; overflow: hidden; font-family: 'Roboto', sans-serif; background: #000; color: #fff; }

  /* ── HEADER ── */
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 0 2rem;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 1px 0 rgba(0,0,0,0.08);
  }
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }
  .header-logo img { height: 32px; width: auto; display: block; }

  /* Nav */
  .nav__list { list-style: none; display: flex; gap: 2rem; }
  .nav__link {
    color: #222;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav__link:hover { color: #e63946; }

  /* Burger */
  .burger { display: none; flex-direction: column; justify-content: center; gap: 5px; width: 36px; height: 36px; cursor: pointer; background: none; border: none; }
  .burger__lines,
  .burger__lines::before,
  .burger__lines::after {
    display: block; width: 24px; height: 2px; background: #222;
    transition: transform 0.3s, opacity 0.3s;
    position: relative;
  }
  .burger__lines::before,
  .burger__lines::after { content: ''; position: absolute; left: 0; }
  .burger__lines::before { top: -7px; }
  .burger__lines::after { top: 7px; }
  .burger[aria-expanded="true"] .burger__lines { background: transparent; }
  .burger[aria-expanded="true"] .burger__lines::before { transform: rotate(45deg) translate(5px, 5px); }
  .burger[aria-expanded="true"] .burger__lines::after { transform: rotate(-45deg) translate(5px, -5px); }

  /* ── SLIDESHOW ── */
  .slideshow {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
  }

  /* ── SLIDES ── */
  .slide {
    position: absolute;
    inset: 0;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow-y: auto;
    overflow-x: hidden;
    padding-top: 70px;
    padding-inline: 30px;
