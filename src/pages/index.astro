</style>

<script>
  // ── SLIDESHOW ENGINE ──
  const slides = document.querySelectorAll<HTMLElement>('.slide');
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  let current = 0;
  let isAnimating = false;
  const SLIDE_COUNT = slides.length;

  // Set first slide active, mark others as inert (removes from tab order)
  slides[0]?.classList.add('slide--active');
  slides.forEach((slide, i) => { if (i !== 0) (slide as HTMLElement).setAttribute('inert', ''); });

  function goTo(index: number) {
    if (isAnimating || index === current) return;
    isAnimating = true;
    const prevSlide = slides[current] as HTMLElement;
    const goingBack = index < current;
    prevSlide?.classList.remove('slide--active');
    prevSlide?.setAttribute('inert', '');
    current = Math.max(0, Math.min(index, SLIDE_COUNT - 1));
    const nextSlide = slides[current] as HTMLElement;
    nextSlide?.classList.add('slide--active');
    nextSlide?.removeAttribute('inert');
    // Going forward → start at top. Going back → start at bottom.
    if (goingBack) {
      nextSlide.scrollTop = nextSlide.scrollHeight;
    } else {
      nextSlide.scrollTop = 0;
    }
    dots.forEach((d, i) => {
      d.classList.toggle('dot--active', i === current);
      d.setAttribute('aria-pressed', String(i === current));
    });
    setTimeout(() => { isAnimating = false; }, 650);
  }

  // After goTo(), move focus to the first focusable element in the new slide
  // so keyboard users continue naturally from there instead of looping the dots
  function focusSlide(index: number) {
    const slide = slides[index] as HTMLElement;
    if (!slide) return;
    const focusable = slide.querySelector<HTMLElement>(
      'a[href], button:not([disabled]), input, textarea, select, [tabindex]:not([tabindex="-1"])'
    );
    if (focusable) {
      focusable.focus();
    } else {
      // No focusable element in slide — return focus to header logo
      (document.querySelector<HTMLElement>('.header-logo') as HTMLElement)?.focus();
    }
  }

  // Dot clicks
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = Number(dot.dataset.slide);
      goTo(idx);
      // Small delay to let slide transition start before moving focus
      setTimeout(() => focusSlide(idx), 50);
    });
  });

  // Keyboard
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') goTo(current + 1);
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   goTo(current - 1);
  });

  // ── SCROLL-BASED SLIDE ADVANCE (overscroll buffer) ──
  // Natural scroll within each slide. Only advance/retreat once the user
  // has overscrolled past the edge by BUFFER px — prevents accidental advances.

  const BUFFER = 60;           // px of overscroll needed to commit
  const SCROLL_END_DELAY = 150; // ms of no wheel → gesture ended
  const SNAP_DURATION = 900;    // ms to lock out further advances after snap

  let overscroll = 0;
  let isSnapping = false;
  let scrollEndTimer: ReturnType<typeof setTimeout> | null = null;

  function getActiveEl(): HTMLElement {
    return slides[current] as HTMLElement;
  }

  function atBottom(el: HTMLElement): boolean {
    return el.scrollTop + el.clientHeight >= el.scrollHeight - 2;
  }

  function atTop(el: HTMLElement): boolean {
    return el.scrollTop <= 0;
  }

  function resetOverscroll() {
    overscroll = 0;
    if (scrollEndTimer) clearTimeout(scrollEndTimer);
    scrollEndTimer = null;
  }

  function snapBack() {
    // bounce back: if overscolling down snap to bottom, up snap to top
    const el = getActiveEl();
    isSnapping = true;
    if (overscroll > 0) {
      el.scrollTop = el.scrollHeight - el.clientHeight;
    } else {
      el.scrollTop = 0;
    }
    setTimeout(() => { isSnapping = false; }, 400);
  }

  function handleWheel(e: WheelEvent) {
    e.preventDefault();
    if (isSnapping || isAnimating) return;

    const direction = Math.sign(e.deltaY); // 1 = down, -1 = up
    const el = getActiveEl();
    const bottom = atBottom(el);
    const top = atTop(el);

    // Not at edge → normal scroll inside slide
    if ((direction > 0 && !bottom) || (direction < 0 && !top)) {
      el.scrollTop += e.deltaY;
      resetOverscroll();
      return;
    }

    // At edge → accumulate overscroll buffer
    overscroll += e.deltaY;
    const absOver = Math.abs(overscroll);
    const overDir = Math.sign(overscroll);

    if (absOver >= BUFFER && overDir === direction) {
      // Committed — advance or retreat
      const next = current + direction;
      if (next >= 0 && next < SLIDE_COUNT) {
        resetOverscroll();
        isSnapping = true;
        goTo(next);
        setTimeout(() => { isSnapping = false; }, SNAP_DURATION);
      } else {
        snapBack();
        resetOverscroll();
      }
    } else {
      // Gesture still accumulating — wait to see if it commits
      if (scrollEndTimer) clearTimeout(scrollEndTimer);
      scrollEndTimer = setTimeout(() => {
        if (Math.abs(overscroll) < BUFFER) snapBack();
        resetOverscroll();
      }, SCROLL_END_DELAY);
    }
  }

  window.addEventListener('wheel', handleWheel, { passive: false });

  // Touch / swipe
  let touchStartX = 0;
  let touchStartY = 0;
  document.addEventListener('touchstart', (e: TouchEvent) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  document.addEventListener('touchend', (e: TouchEvent) => {
    if (isSnapping || isAnimating) return;
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    const el = getActiveEl();
    if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 80) {
      if (dy < 0 && atBottom(el)) goTo(current + 1);
      if (dy > 0 && atTop(el)) goTo(current - 1);
    }
  }, { passive: true });

  // Nav anchor links
  const slideIds = JSON.parse(document.getElementById('slide-ids-data')?.textContent ?? '[]');
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
    a.addEventListener('click', (e: Event) => {
      const hash = (a.getAttribute('href') ?? '').replace('#', '');
      const idx = slideIds.indexOf(hash);
      if (idx !== -1) {
        e.preventDefault();
        goTo(idx);
        // close mobile nav
        nav.classList.remove('nav--open');
        burger.setAttribute('aria-expanded', 'false');
        // Move focus into the new slide
        setTimeout(() => focusSlide(idx), 50);
      }
    });
  });

  // Mobile arrows
  document.getElementById('prevBtn')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('nextBtn')?.addEventListener('click', () => goTo(current + 1));

  // ── FOCUS-DRIVEN SLIDE NAVIGATION (accessibility) ──
  // When a keyboard user tabs to a focusable element on a non-active slide,
  // automatically jump to that slide so the screen follows focus.
  document.getElementById('slideshow')?.addEventListener('focusin', (e: Event) => {
    const target = e.target as HTMLElement;
    const parentSlide = target.closest<HTMLElement>('.slide');
    if (!parentSlide) return;
    const idx = Array.from(slides).indexOf(parentSlide);
    if (idx !== -1 && idx !== current) goTo(idx);
  });

  // ── CONTACT FORM ──
  document.getElementById('contactForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = document.getElementById('contactSubmit') as HTMLButtonElement;
    const success = document.getElementById('contactSuccess') as HTMLElement;
    const error = document.getElementById('contactError') as HTMLElement;

    btn.disabled = true;
    btn.textContent = 'Sending…';
    success.style.display = 'none';
    error.style.display = 'none';

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
      const json = await res.json();
      if (json.success) {
        success.style.display = 'block';
        form.reset();
      } else {
        error.style.display = 'block';
      }
    } catch {
      error.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });

  // ── MOBILE BURGER ──
  const burger = document.getElementById('burger') as HTMLButtonElement;
  const nav = document.getElementById('nav') as HTMLElement;
  burger.addEventListener('click', () => {
    const isOpen = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!isOpen));
    nav.classList.toggle('nav--open', !isOpen);
  });
</script>
